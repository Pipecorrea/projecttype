# Copia este archivo a `.env` y completa tus valores:
#   cp .env.example .env

# --- LLM provider (mismo mapa que OBSRATE) ---
# "gemini" (default): Gemini en Vertex AI (ADC + GOOGLE_CLOUD_PROJECT).
# "gemini-studio": Gemini vía Google AI Studio (GEMINI_API_KEY, cuota gratuita).
# "vertex": Claude vía Vertex AI (requiere Enable por modelo).
# "anthropic": Anthropic API directa.
# "openai" / "ollama": alternativas locales o API.
# Vertex usa ADC: gcloud auth application-default login
LLM_PROVIDER=gemini

# --- Google Cloud (Vertex: gemini y vertex) ---
GOOGLE_CLOUD_PROJECT=
# "global" (default) enruta a cualquier región con capacidad — remedio oficial
# para los 429 RESOURCE_EXHAUSTED de la Dynamic Shared Quota. Una región fija
# (p. ej. us-central1) solo si algo lo exige (CMEK, residencia de datos).
# us-east5 es región de Claude: NUNCA para Gemini (90% de 429 en corrida real).
GOOGLE_CLOUD_REGION=global

# --- Google AI Studio (solo si LLM_PROVIDER=gemini-studio) ---
GEMINI_API_KEY=

# Modelo L3 (default del código: gemini-2.5-flash — en retiro 2026-10-16, su
# capacidad DSQ decrece). Verificados en Vertex global 2026-07-15:
#   gemini-3.1-flash-lite (GA, $0.25/$1.50 por 1M — recomendado para L3)
#   gemini-3-flash-preview ($0.50/$3.00) | gemini-3.5-flash (GA, $1.50/$9.00)
# gemini-3.1-flash NO existe. Ojo: cambiar de modelo enfría el caché L3
# (keyed por modelo) — re-paga llamadas.
LLM_MODEL=gemini-3.1-flash-lite

# Hilos paralelos para llamadas L3 (default 5, como OBSRATE)
# LLM_MAX_CONCURRENCY=5

# Throttle solo para AI Studio free tier (Vertex: dejar en 0 o sin definir)
# GEMINI_REQUEST_INTERVAL=0

# --- OpenAI (si LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=

# --- Ollama local ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b-instruct
