# Copia este archivo a `.env` y completa tus valores:
#   cp .env.example .env

# Gemini (Google AI Studio) — L3 con --l3-provider google
GEMINI_API_KEY=

# Opcional: modelo Gemini (default: gemini-2.5-flash — free tier activo en AI Studio)
# GEMINI_MODEL=gemini-2.5-flash

# OpenAI — L3 con --l3-provider openai
# OPENAI_API_KEY=

# Ollama local — L3 con --l3-provider ollama (default)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b-instruct
